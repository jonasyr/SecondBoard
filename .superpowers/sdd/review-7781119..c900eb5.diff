+	it('produces one evalPerPly entry per mock position, normalized to White POV', async () => {
+		analyzeFen.mockImplementation(async () => ({
+			evalCp: 50,
+			isMate: false,
+			bestMoveUci: 'e2e4',
+			pv: []
