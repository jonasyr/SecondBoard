+		lastMoveColor: string;
+		showCoords: boolean;
+	}
+
+	let { square, lastMoveColor, showCoords }: Props = $props();
+
+	const spriteKey = $derived(
+		square.piece ? ((square.piece[1] + square.piece[0]) as PieceSpriteKey) : null
+	);
+</script>
