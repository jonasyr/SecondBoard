+		expect(center('e4', false)).toEqual({ x: 337.5, y: 337.5 });
+	});
+
+	it('maps e4 to its pixel center, flipped', () => {
+		// col=7-4=3, rowTop=4-1=3 -> x=3*75+37.5=262.5, y=262.5
+		expect(center('e4', true)).toEqual({ x: 262.5, y: 262.5 });
