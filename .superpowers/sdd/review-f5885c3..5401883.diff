+describe('parsePgn', () => {
+	it('invokes the parse_pgn command with the given PGN text and returns its result', async () => {
+		invoke.mockResolvedValue({
+			sanList: ['e4', 'e5'],
+			positions: [{ e2: ['P', 'w'] }, { e4: ['P', 'w'] }],
+			moves: [{ from: 'e2', to: 'e4' }]
